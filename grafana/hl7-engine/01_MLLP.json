{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "uid": "hl7-mllp",
  "title": "01_MLLP",
  "tags": ["hl7", "MLLP"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "style": "dark",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active MLLP Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
          { "refId": "A", "expr": "sum(hl7_mllp_connections_active)" }
      ],
      "fieldConfig": {
          "defaults": {
          "unit": "none",
          "thresholds": {
              "mode": "absolute",
              "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
              ]
          }
          },
          "overrides": []
      },
      "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "orientation": "horizontal",
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Bytes Received (per second)",
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 0 },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(hl7_mllp_bytes_received_total[1m])",
          "legendFormat": "bytes/s",
          "interval": ""
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bytes Sent (per second)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
          { "refId": "A", "expr": "rate(hl7_mllp_bytes_sent_total[1m])", "legendFormat": "bytes/s" }
      ],
      "fieldConfig": {
          "defaults": { "unit": "Bps" },
          "overrides": []
      },
      "options": {
          "legend": { "displayMode": "table", "placement": "bottom" },
          "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Frame Errors (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
          { "refId": "A", "expr": "increase(hl7_mllp_frame_errors_total[5m])" }
      ],
      "fieldConfig": {
          "defaults": {
          "unit": "none",
          "thresholds": {
              "mode": "absolute",
              "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
              ]
          }
          },
          "overrides": []
      },
      "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "orientation": "horizontal",
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection Errors (5m)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
          { "refId": "A", "expr": "increase(hl7_mllp_connection_errors_total[5m])", "legendFormat": "errors" }
      ],
      "fieldConfig": {
          "defaults": { "unit": "none" },
          "overrides": []
      },
      "options": {
          "legend": { "displayMode": "table", "placement": "bottom" },
          "tooltip": { "mode": "single" }
      }
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  }
}