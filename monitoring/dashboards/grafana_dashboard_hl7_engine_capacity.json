{
  "title": "HL7 Engine — Capacity Planning",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [

    {
      "type": "row",
      "title": "Load & Throughput",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "type": "timeseries",
      "title": "Messages per second",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "targets": [
        { "expr": "rate(hl7_messages_received[1m])", "legendFormat": "received" }
      ]
    },

    {
      "type": "timeseries",
      "title": "ACKs per second",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "expr": "rate(hl7_acks_sent[1m])", "legendFormat": "acks" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Slow-path throughput (msg/sec)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        { "expr": "rate(hl7_messages_processed[1m])", "legendFormat": "processed" }
      ]
    },

    {
      "type": "row",
      "title": "Worker Pool Capacity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "type": "timeseries",
      "title": "Worker Saturation",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "hl7_workers_busy / hl7_workers_max", "legendFormat": "saturation" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Worker Tasks per second",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(hl7_worker_tasks[1m])", "legendFormat": "tasks/sec" }
      ]
    },

    {
      "type": "row",
      "title": "Queue Capacity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 }
    },

    {
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 11 },
      "targets": [
        { "expr": "hl7_queue_depth", "legendFormat": "depth" }
      ]
    },

    {
      "type": "stat",
      "title": "Queue Overflow Events",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 11 },
      "targets": [
        { "expr": "increase(hl7_queue_overflow[5m])", "legendFormat": "overflow" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Queue Depth vs Worker Saturation",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "targets": [
        { "expr": "hl7_queue_depth", "legendFormat": "queue depth" },
        { "expr": "hl7_workers_busy / hl7_workers_max", "legendFormat": "worker saturation" }
      ]
    },

    {
      "type": "row",
      "title": "Slow Path Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },

    {
      "type": "timeseries",
      "title": "Slow Phase Latency (ms)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "targets": [
        { "expr": "hl7_slow_phase_latency_ms_p95", "legendFormat": "p95" },
        { "expr": "hl7_slow_phase_latency_ms_p99", "legendFormat": "p99" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Routing Latency (ms)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 22 },
      "targets": [
        { "expr": "hl7_routing_latency_ms_p95", "legendFormat": "p95" },
        { "expr": "hl7_routing_latency_ms_p99", "legendFormat": "p99" }
      ]
    },

    {
      "type": "timeseries",
      "title": "File Write Latency (ms)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "targets": [
        { "expr": "hl7_file_write_latency_ms_p95", "legendFormat": "p95" },
        { "expr": "hl7_file_write_latency_ms_p99", "legendFormat": "p99" }
      ]
    },

    {
      "type": "row",
      "title": "SQLite Capacity",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },

    {
      "type": "timeseries",
      "title": "DB Insert Latency (ms)",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 27 },
      "targets": [
        { "expr": "hl7_db_insert_latency_ms_p95", "legendFormat": "p95" },
        { "expr": "hl7_db_insert_latency_ms_p99", "legendFormat": "p99" }
      ]
    },

    {
      "type": "stat",
      "title": "DB Insert Failures",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 27 },
      "targets": [
        { "expr": "increase(hl7_db_insert_failure[5m])", "legendFormat": "failures" }
      ]
    },

    {
      "type": "timeseries",
      "title": "DB File Size (MB)",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 31 },
      "targets": [
        { "expr": "hl7_db_file_size_mb", "legendFormat": "file size" }
      ]
    },

    {
      "type": "timeseries",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 31 },
      "targets": [
        { "expr": "hl7_active_connections", "legendFormat": "connections" }
      ]
    }

  ]
}