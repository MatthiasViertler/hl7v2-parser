{
  "title": "HL7 Engine — Sender SLA/SLO Dashboard",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [

    {
      "type": "row",
      "title": "ACK Latency SLO (Fast Path)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "type": "timeseries",
      "title": "ACK Latency p95 per Sender (SLO: <50ms)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "topk(10, {__name__=~\"sender_ack_latency_ms_.*_p95\"})",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "ACK Latency p95 per Facility (SLO: <50ms)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "topk(10, {__name__=~\"facility_ack_latency_ms_.*_p95\"})",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "row",
      "title": "End-to-End Latency SLO (Slow Path)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },

    {
      "type": "timeseries",
      "title": "End-to-End Latency p95 per Facility (SLO: <500ms)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "topk(10, {__name__=~\"facility_e2e_latency_ms_.*_p95\"})",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "row",
      "title": "Parse Success SLO (99%+)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },

    {
      "type": "timeseries",
      "title": "Parse Failure Rate per Sender (SLO: <1%)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "topk(10, increase({__name__=~\"sender_parse_failure_.*\"}[5m]))",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Parse Failure Rate per Facility (SLO: <1%)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 21 },
      "targets": [
        {
          "expr": "topk(10, increase({__name__=~\"facility_parse_failure_.*\"}[5m]))",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "row",
      "title": "Validation Success SLO (98%+)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },

    {
      "type": "timeseries",
      "title": "Validation Failure Rate per Sender (SLO: <2%)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "topk(10, increase({__name__=~\"sender_validation_failure_.*\"}[5m]))",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Validation Failure Rate per Facility (SLO: <2%)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "topk(10, increase({__name__=~\"facility_validation_failure_.*\"}[5m]))",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "row",
      "title": "Message Loss SLO (0 Loss)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }
    },

    {
      "type": "stat",
      "title": "Queue Overflow Events (SLO: 0)",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 35 },
      "targets": [
        {
          "expr": "increase(hl7_queue_overflow[5m])",
          "legendFormat": "overflow"
        }
      ]
    },

    {
      "type": "row",
      "title": "DB Reliability SLO (99.99%+)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 }
    },

    {
      "type": "timeseries",
      "title": "DB Insert Failures per Sender",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "topk(10, increase({__name__=~\"sender_db_failure_.*\"}[5m]))",
          "legendFormat": "{{__name__}}"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "DB Insert Failures (Global)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "increase(hl7_db_insert_failure[5m])",
          "legendFormat": "db failures"
        }
      ]
    }

  ]
}